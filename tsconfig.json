{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "removeComments": false,
    "outDir": ".cache/ts",
    "rootDir": "src/js"
  },
  "include": ["src/js/**/*.ts"],
  "exclude": []
}
